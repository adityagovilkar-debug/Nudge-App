# Copy this file to `.env.local` and fill in your Supabase project values.
# Find these in your Supabase dashboard → Project Settings → API.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional but recommended: the public site URL, used to build links in
# reminder emails (e.g. https://nudge.vercel.app). Defaults to the app origin.
NEXT_PUBLIC_SITE_URL=http://localhost:3020

# =====================================================================
# Daily reminder email — only needed for the `daily-digest` Edge Function.
# These are set as Supabase *function secrets*, not in the browser bundle.
#   supabase secrets set RESEND_API_KEY=... REMINDER_EMAIL_FROM="Nudge <...>"
# =====================================================================
# Resend API key for sending the morning digest (https://resend.com — free tier)
RESEND_API_KEY=your-resend-key
# Address the digest is sent from (must be a verified Resend sender/domain).
# resend.dev works out of the box for testing.
REMINDER_EMAIL_FROM=Nudge <onboarding@resend.dev>
# Hour of day (0-23, in each user's local timezone) to send the morning
# digest. Optional — defaults to 7 (7am) if unset.
REMINDER_HOUR=7
# Public site URL, used for the "Open Nudge" button in the reminder email.
SITE_URL=https://nudge-app-zeta.vercel.app
# Service role key (KEEP SECRET) — the digest function reads every user's
# errands with the service role. Supabase injects this into Edge Functions
# automatically, so you usually do NOT need to set it yourself.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =====================================================================
# Web Push notifications (phone reminders) — set these in Vercel.
# Generate the VAPID pair once:  npx web-push generate-vapid-keys
# =====================================================================
# Public key — safe to expose to the browser.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
# Private key (KEEP SECRET — server only).
VAPID_PRIVATE_KEY=your-vapid-private-key
# Contact for push services, e.g. mailto:you@example.com
VAPID_SUBJECT=mailto:you@example.com
# Long random string; Supabase pg_cron sends it as a bearer token to
# /api/push/send so only the cron can trigger sends.
CRON_SECRET=any-long-random-string
# Server-only Supabase key (KEEP SECRET). The push send route runs on Vercel
# (not Supabase), so it must be set here explicitly — it is NOT auto-injected.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
